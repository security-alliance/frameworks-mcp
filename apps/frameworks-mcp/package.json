{
  "name": "@security-alliance/frameworks-mcp",
  "version": "1.0.0",
  "description": "Public read-only MCP server for SEAL Frameworks documentation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/security-alliance/frameworks",
    "directory": "apps/frameworks-mcp"
  },
  "homepage": "https://github.com/security-alliance/frameworks#readme",
  "bin": {
    "frameworks-mcp": "./dist/index.js",
    "frameworks-mcp-http": "./dist/http-server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "serve:http": "tsx src/http-server.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@security-alliance/frameworks-indexer": "workspace:*",
    "minisearch": "^6.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}